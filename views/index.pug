extends layouts/main

block content
  .row.justify-content-center.align-items-center.py-5
    .col-md-8.text-center
      h1.display-4.fw-bold.text-dark Bienvenido a Fotaza
      p.lead.text-secondary La plataforma donde tus fotografías tienen valor. Subí tus imágenes y monetizá tu contenido de forma segura.
      hr.my-4
      
      .d-grid.gap-3.d-sm-flex.justify-content-sm-center.mt-4
        a.btn.btn-primary.btn-lg.px-4.gap-3(href="/register") Crear Cuenta
        a.btn.btn-outline-secondary.btn-lg.px-4(href="/posts") Ver Fotos

  .container.my-5.pt-5.text-center
    .row.justify-content-center
      .col-12.col-md-10.col-lg-8
        .ratio.ratio-16x9.shadow-lg.rounded-4.overflow-hidden(style="border: 1px solid var(--bs-border-color);")
          iframe(src="https://www.youtube.com/embed/wmiqfi5mVlI?si=pW6nnFfLFi6nhcsP" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen)