extends layouts/main.pug

block content
  .container
    .row.mb-4
      .col
        h1.fw-bold Notificaciones
        p.text-muted Mantenete al tanto de la actividad de tu cuenta.

    .row
      .col-md-8
        if notifications && notifications.length > 0
          .list-group
            each notif in notifications
              .list-group-item.list-group-item-action.d-flex.align-items-center.gap-3.py-3
                if notif.type === 'COMMENT'
                  i.bi.bi-chat-dots.fs-3
                  div #[strong #{notif.sourceUser ? notif.sourceUser.username : 'Alguien'}] comentó tu publicación.
                else if notif.type === 'RATE'
                  i.bi.bi-heart-fill.fs-3
                  div #[strong #{notif.sourceUser ? notif.sourceUser.username : 'Alguien'}] calificó tu fotografía.
                else if notif.type === 'FOLLOW'
                  i.bi.bi-person-plus-fill.fs-3
                  div #[strong #{notif.sourceUser ? notif.sourceUser.username : 'Alguien'}] comenzó a seguirte.
                else if notif.type === 'PURCHASE'
                  i.bi.bi-cash-coin.fs-3
                  div ¡Felicitaciones! #[strong #{notif.sourceUser ? notif.sourceUser.username : 'Alguien'}] compró tu fotografía.
        else
          .alert.alert-light.text-center.py-5
            i.bi.bi-bell-slash.fs-1.text-muted.mb-3.d-block
            h5.text-muted No tenés notificaciones