extends layouts/main.pug

block content
  .container

    - const coverColors = ['#2D2A3E', '#1F2937', '#2A2438', '#1C2B36', '#302430', '#212A2F'];
    - const userIndex = profileUser && profileUser.username ? profileUser.username.charCodeAt(0) : 2;
    - const defaultCover = coverColors[userIndex % coverColors.length];

    .position-relative.mb-5
      if profileUser && profileUser.coverUrl
        img.w-100.rounded-4.shadow-sm(src=profileUser.coverUrl style="height: 250px; object-fit: cover; filter: brightness(0.8);" alt="Portada de Perfil")
      else
        .w-100.rounded-4.shadow-sm(style=`height: 250px; background-color: ${defaultCover};`)
      
      .position-absolute.top-100.start-50.translate-middle
        if profileUser && profileUser.avatarUrl
          img.rounded-circle.shadow-lg(src=profileUser.avatarUrl alt="Avatar" style="width: 140px; height: 140px; object-fit: cover; border: 6px solid var(--bg-main); background-color: var(--bg-main);")
        else
          .d-flex.justify-content-center.align-items-center.rounded-circle.shadow-lg(style="width: 140px; height: 140px; border: 6px solid var(--bg-main); background-color: var(--bg-surface); color: var(--text-muted); margin: 0;")
            i.bi.bi-person-fill(style="font-size: 80px;")


    .text-center.mt-5.pt-3.mb-4
      h2.fw-bold.mb-1 #{profileUser.username}
      p.text-muted.mb-3 #{profileUser.bio || '¡Hola! Estoy usando Fotaza para compartir mi arte.'}
      a.text-decoration-none.d-block.mb-3.text-primary(href="#") 
      
      .d-flex.justify-content-center.gap-2
        if user && profileUser.id === user.id
          a.btn.btn-sm.btn-outline-secondary.px-3(href="/profile/edit" title="Editar Perfil" style="border-radius: 20px;") Editar perfil
        else if user
          - const isFollowing = profileUser.followers && profileUser.followers.some(f => f.id === user.id)
          form(action=`/profile/${profileUser.id}/follow` method="POST" class="m-0")
            button.btn.btn-sm.px-4.fw-bold(type="submit" style=`background-color: ${isFollowing ? 'transparent' : 'var(--text-main)'}; color: ${isFollowing ? 'var(--text-main)' : 'var(--bg-main)'}; border: 1px solid var(--text-main); border-radius: 20px;`)
              if isFollowing
                | Dejar de seguir
              else
                | Seguir


    .row.justify-content-center.mb-5
      .col-12.col-md-8.col-lg-6
        .card.border-0.shadow-lg(style="background-color: var(--bg-surface); border-radius: 24px;")
          .card-body.d-flex.justify-content-around.py-3
            .text-center
              h4.fw-bold.mb-0 #{profileUser.posts ? profileUser.posts.length : 0}
              span.text-muted.small.fw-bold PUBLICACIONES
            .text-center(style="cursor: pointer;" data-bs-toggle="modal" data-bs-target="#followersModal")
              h4.fw-bold.mb-0 #{profileUser.followers ? profileUser.followers.length : 0}
              span.text-muted.small.fw-bold SEGUIDORES
            .text-center(style="cursor: pointer;" data-bs-toggle="modal" data-bs-target="#followingModal")
              h4.fw-bold.mb-0 #{profileUser.following ? profileUser.following.length : 0}
              span.text-muted.small.fw-bold SEGUIDOS

    .d-flex.justify-content-between.align-items-center.mb-4
      h4.fw-bold.mb-0 Posts
      select.form-select.form-select-sm.w-auto.bg-transparent.text-muted.border-secondary
        option(selected) Más recientes
        option Populares

    .row.g-4.mb-5
      if profileUser.posts && profileUser.posts.length > 0
        each post in profileUser.posts
          .col-12.col-sm-6.col-md-4
            - const images = post.imagesList && post.imagesList.length > 0 ? post.imagesList : (Array.isArray(post.image) ? post.image : (post.image ? [post.image] : []))
            if images.length > 0
              div.ratio.ratio-1x1.d-block.rounded-4.overflow-hidden.shadow-sm(data-bs-toggle="modal" data-bs-target=`#postModal-${post.id}` style="cursor: pointer;")
                img.object-fit-cover(src=images[0].filePath alt=`Post ${post.id}` style="transition: transform 0.4s ease, filter 0.4s ease;" onmouseover="this.style.transform='scale(1.08)'; this.style.filter='brightness(0.7)';" onmouseout="this.style.transform='scale(1)'; this.style.filter='brightness(1)';")
            else
              .alert.alert-danger.small.text-center Imagen no encontrada

      else
        .col-12.text-center.py-5
          p.text-muted Todavía no hay publicaciones.

    if user
      a.btn.btn-primary.position-fixed.bottom-0.end-0.m-4.rounded-circle.shadow-lg.d-flex.justify-content-center.align-items-center(href="/posts/create" style="width: 60px; height: 60px; background-color: var(--accent); border: none; z-index: 1000;" title="Subir Foto")
        i.bi.bi-plus-lg.fs-3

    if profileUser.posts && profileUser.posts.length > 0
      each post in profileUser.posts
        - const images = post.imagesList && post.imagesList.length > 0 ? post.imagesList : (Array.isArray(post.image) ? post.image : (post.image ? [post.image] : []))
        if images.length > 0
          .modal.fade(id=`postModal-${post.id}` tabindex="-1" aria-hidden="true")
            .modal-dialog.modal-dialog-centered.modal-xl
              .modal-content.bg-transparent.border-0
                .modal-body.p-0.position-relative.text-center
                  button.btn-close.btn-close-white.position-absolute.top-0.end-0.m-3(type="button" data-bs-dismiss="modal" aria-label="Close" style="z-index: 1055;")
                  
                  if images.length > 1
                    div.carousel.slide(id=`carouselModal-${post.id}` data-bs-ride="false" data-bs-wrap="false" data-bs-interval="false")
                      div.carousel-inner
                        each img, index in images
                          div.carousel-item(class=(index === 0 ? 'active' : ''))
                            img.img-fluid(src=img.filePath alt="Post image" style="max-height: 90vh; object-fit: contain;")
                      
                      button.carousel-control-prev(type="button" data-bs-target=`#carouselModal-${post.id}` data-bs-slide="prev" style="background-color: rgba(0,0,0,0.6); width: 40px; height: 40px; border-radius: 50%; top: 50%; transform: translateY(-50%); left: 10px; opacity: 1;")
                        span.fw-bold.fs-5(style="color: white; line-height: 1;") &lt;
                      button.carousel-control-next(type="button" data-bs-target=`#carouselModal-${post.id}` data-bs-slide="next" style="background-color: rgba(0,0,0,0.6); width: 40px; height: 40px; border-radius: 50%; top: 50%; transform: translateY(-50%); right: 10px; opacity: 1;")
                        span.fw-bold.fs-5(style="color: white; line-height: 1;") &gt;
                  else
                    img.img-fluid(src=images[0].filePath alt="Post image" style="max-height: 90vh; object-fit: contain;")

    if profileUser.followers
      .modal.fade(id="followersModal" tabindex="-1")
        .modal-dialog.modal-dialog-centered.modal-dialog-scrollable
          .modal-content(style="background-color: var(--bg-surface);")
            .modal-header.border-secondary
              h5.modal-title.fw-bold Seguidores
              button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
            .modal-body
              if profileUser.followers.length > 0
                .list-group
                  each follower in profileUser.followers
                    a.list-group-item.list-group-item-action.d-flex.align-items-center.bg-transparent.border-secondary(href=`/profile/${follower.id}` style="color: inherit;")
                      if follower.avatarUrl
                        img.rounded-circle.me-3(src=follower.avatarUrl width="40" height="40" style="object-fit: cover;")
                      else
                        i.bi.bi-person-circle.fs-3.me-3(style="color: var(--text-muted);")
                      span.fw-bold #{follower.username}
              else
                p.text-muted.text-center.my-3 No tiene seguidores aún.

    if profileUser.following
      .modal.fade(id="followingModal" tabindex="-1")
        .modal-dialog.modal-dialog-centered.modal-dialog-scrollable
          .modal-content(style="background-color: var(--bg-surface);")
            .modal-header.border-secondary
              h5.modal-title.fw-bold Seguidos
              button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
            .modal-body
              if profileUser.following.length > 0
                .list-group
                  each followed in profileUser.following
                    a.list-group-item.list-group-item-action.d-flex.align-items-center.bg-transparent.border-secondary(href=`/profile/${followed.id}` style="color: inherit;")
                      if followed.avatarUrl
                        img.rounded-circle.me-3(src=followed.avatarUrl width="40" height="40" style="object-fit: cover;")
                      else
                        i.bi.bi-person-circle.fs-3.me-3(style="color: var(--text-muted);")
                      span.fw-bold #{followed.username}
              else
                p.text-muted.text-center.my-3 No sigue a nadie aún.
