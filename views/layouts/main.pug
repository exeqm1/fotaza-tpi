doctype html
html(lang="es" data-bs-theme="dark")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Fotaza
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css")
    link(rel="stylesheet" href="/styles.css")
  
  body.d-flex.flex-column.min-vh-100.fw-light

    nav.navbar.navbar-expand-lg.shadow-sm
      .container
        a.navbar-brand.fw-bold.d-flex.align-items-center(href="/")
          img.me-2(src="/resources/img/logo-soft.png" alt="Logo" height="40")
          span.logo fotaza
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav")
          span.navbar-toggler-icon
        .collapse.navbar-collapse#navbarNav
          if user
            form.d-flex.mx-auto.my-2.my-lg-0(action="/posts" method="GET" style="max-width: 400px; width: 100%;")
              .input-group.input-group-sm
                input.form-control.border-secondary.bg-transparent.shadow-none(type="search" name="q" placeholder="Buscar usuarios o publicaciones..." value=(typeof query !== 'undefined' ? query : '') style="color: inherit; box-shadow: none; outline: none;")
                button.btn.btn-outline-secondary(type="submit" style="background-color: var(--bg-surface); border-color: var(--bs-border-color);")
                  i.bi.bi-search
          ul.navbar-nav.ms-auto
            li.nav-item
              a.nav-link(href="/") Inicio
            li.nav-item
              a.nav-link(href="/posts") Explorar
            if user
              li.nav-item
                a.nav-link(href="/profile") #{user.username}
              if user.role === 'ADMIN'
                li.nav-item
                  a.nav-link(href="/admin") Admin
              li.nav-item
                a.nav-link.text-danger(href="/auth/logout") Salir
            if !user
              li.nav-item
                a.nav-link(href="/login") Ingresar

    main.container.my-5.flex-grow-1
      block content

    footer.text-center.py-3.mt-auto
      .container
        p.mb-0.small &copy; #{new Date().getFullYear()} Fotaza - Trabajo Práctico Integrador.
        a.footer-link(href="github.com/exeqm1") exeqm1
    
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")