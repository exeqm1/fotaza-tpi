extends layouts/main.pug

block content
  .container
    .row.mb-4
      .col
        h1.fw-bold Panel de Moderación
        p.text-muted Gestioná los reportes y el estado de la comunidad.

    .row
      .col-12
        .card.border-0.shadow-lg(style="background-color: var(--bg-surface);")
          .card-body.p-4
            h4.fw-bold.mb-4 Reportes Pendientes
            
            .table-responsive
              table.table.table-striped.table-hover.align-middle
                thead
                  tr
                    th ID
                    th Usuario
                    th Estado / Strikes
                    th Correo Electrónico
                    th Acciones
                tbody
                  if users && users.length > 0
                    each u in users
                      tr
                        td ##{u.id}
                        td.fw-bold
                          a.text-decoration-none(href=`/profile/${u.id}` style="color: inherit;") #{u.username}
                        td 
                          if u.status === 'BANNED'
                            span.badge.bg-danger Baneado
                          else
                            | Strikes: #{u.strikes}
                        td #{u.email}
                        td
                          .d-flex.align-items-center
                            if u.status !== 'BANNED'
                              form(action=`/admin/strike/${u.id}` method="POST" class="m-0 p-0")
                                button.btn.btn-sm.btn-danger.me-2(title="Aplicar Strike / Banear" type="submit")
                                  i.bi.bi-hammer.me-1
                                  | Sancionar
                            else
                              button.btn.btn-sm.btn-secondary.me-2(disabled) Sancionado
                  else
                    tr
                      td(colspan="5").text-center.text-muted No hay usuarios registrados o reportados.