extends layouts/main.pug

block content
  .container
    .row.mb-5.text-center
      .col
        h1.fw-bold.mb-2 Explorar Feed
        p.text-muted Descubrí las mejores fotografías de nuestra comunidad.

    if query && users && users.length > 0
      .row.justify-content-center.mb-4
        .col-12.col-md-8.col-lg-6
          h5.fw-bold.mb-3 Usuarios encontrados
          .d-flex.flex-wrap.gap-3
            each u in users
              .card.border-0.shadow-sm.text-center.p-3(style="width: 140px; background-color: var(--bg-surface);")
                if u.avatarUrl
                  img.rounded-circle.mx-auto.mb-2(src=u.avatarUrl alt="Avatar" style="width: 60px; height: 60px; object-fit: cover;")
                else
                  .d-flex.justify-content-center.align-items-center.rounded-circle.mx-auto.mb-2(style="width: 60px; height: 60px; background-color: var(--bg-main); color: var(--text-muted);")
                    i.bi.bi-person-fill.fs-3
                a.text-decoration-none.fw-bold(href=`/profile/${u.id}` style="color: inherit;") #{u.username}

    .row.justify-content-center
      .col-12.col-md-8.col-lg-6
        .d-flex.flex-column.gap-5.mb-5
          if posts && posts.length > 0
            each post in posts
              .card.border-0.post-card
                - const isOwner = user && post.userId === user.id
                .card-header.bg-transparent.border-0.d-flex.align-items-center.justify-content-between.py-3
                  a.d-flex.align-items-center.text-decoration-none(href=`/profile/${post.userId}` style="color: inherit;")
                    if post.user && post.user.avatarUrl
                      img.rounded-circle.me-3(src=post.user.avatarUrl alt="Avatar" width="40" height="40" style="object-fit: cover;")
                    else
                      i.bi.bi-person-circle.fs-2.me-3(style="color: var(--text-muted);")
                    span.fw-bold #{post.user ? post.user.username : 'Usuario'}
                  if user
                    .dropdown
                      button.btn.btn-link.text-muted.p-0(type="button" data-bs-toggle="dropdown" aria-expanded="false")
                        i.bi.bi-three-dots-vertical.fs-5
                      ul.dropdown-menu.dropdown-menu-end.shadow-sm(style="background-color: var(--bg-surface); border: 1px solid var(--bs-border-color);")
                        if isOwner
                          li
                            form(action=`/posts/${post.id}/toggle-comments` method="POST" class="m-0")
                              button.dropdown-item(type="submit")
                                if post.allowComments
                                  i.bi.bi-chat-slash.me-2
                                  | Cerrar comentarios
                                else
                                  i.bi.bi-chat-dots.me-2
                                  | Abrir comentarios
                        else
                          li
                            button.dropdown-item.text-danger(type="button" data-bs-toggle="modal" data-bs-target=`#reportPostModal-${post.id}`)
                              i.bi.bi-flag.me-2
                              | Reportar publicación

                - const hasPurchased = post.purchases && post.purchases.length > 0
                - const isLocked = post.forSale && post.price > 0 && !isOwner && !hasPurchased
                - const images = (post.dataValues && post.dataValues.imagesList && post.dataValues.imagesList.length > 0) ? post.dataValues.imagesList : (post.imagesList && post.imagesList.length > 0 ? post.imagesList : (Array.isArray(post.image) ? post.image : (post.image ? [post.image] : [])))
                
                .position-relative
                  if images.length > 1
                    div.carousel.slide(id=`carousel-${post.id}` data-bs-ride="false" data-bs-wrap="false" data-bs-interval="false" data-bs-theme="dark")
                      div.carousel-inner
                        each img, index in images
                          div.carousel-item(class=(index === 0 ? 'active' : ''))
                            img.card-img-top.rounded-0(src=img.filePath alt="Post image" style=`object-fit: cover; max-height: 600px; ${isLocked ? 'filter: blur(25px); pointer-events: none;' : ''}`)
                      button.carousel-control-prev(type="button" data-bs-target=`#carousel-${post.id}` data-bs-slide="prev" style="background-color: rgba(0,0,0,0.6); width: 40px; height: 40px; border-radius: 50%; top: 50%; transform: translateY(-50%); left: 10px; opacity: 1;")
                        span.fw-bold.fs-5(style="color: white; line-height: 1;") &lt;
                      button.carousel-control-next(type="button" data-bs-target=`#carousel-${post.id}` data-bs-slide="next" style="background-color: rgba(0,0,0,0.6); width: 40px; height: 40px; border-radius: 50%; top: 50%; transform: translateY(-50%); right: 10px; opacity: 1;")
                        span.fw-bold.fs-5(style="color: white; line-height: 1;") &gt;
                  else if images.length === 1
                    img.card-img-top.rounded-0(src=images[0].filePath alt="Post image" style=`object-fit: cover; max-height: 600px; ${isLocked ? 'filter: blur(25px); pointer-events: none;' : ''}`)
                  else
                    img.card-img-top.rounded-0(src=`https://picsum.photos/600/600?random=${post.id}` alt="Post image" style=`object-fit: cover; max-height: 600px; ${isLocked ? 'filter: blur(25px); pointer-events: none;' : ''}`)

                  if isLocked
                    .position-absolute.top-50.start-50.translate-middle.text-center.w-100
                      form(action=`/posts/buy/${post.id}` method="POST")
                        button.btn.btn-primary.btn-lg.fw-bold.shadow(type="submit" style="border-radius: 30px; padding: 12px 30px;")
                          i.bi.bi-unlock-fill.me-2
                          | Desbloquear por $#{post.price}

                .card-body
                  .d-flex.justify-content-between.align-items-center.mb-3
                    .d-flex.align-items-center.gap-4
                      
                      form(action=`/posts/rate/${post.id}` method="POST").rating-container.d-flex.flex-row-reverse.align-items-center.m-0
                        span.ms-2.text-muted.small (#{post.averageRating ? parseFloat(post.averageRating).toFixed(1) : '0.0'})
                        - const userRating = post.ratings && post.ratings.length > 0 ? post.ratings[0].value : 0
                        each star in [5, 4, 3, 2, 1]
                          button.rating-heart.fs-5.px-1(type="submit" name="rating" value=star class=(star <= userRating ? 'bi bi-heart-fill text-danger' : 'bi bi-heart') style="background:none; border:none; padding:0; cursor:pointer;" title=`Dar ${star} puntos`)

                      i.bi.bi-chat-dots.comment-btn.fs-5(style="cursor: pointer;" onclick=`document.getElementById('comment-input-${post.id}').focus()`)
                    div.d-flex.align-items-center.gap-2
                      if post.forSale
                        span.badge.bg-dark.text-light.border.border-secondary En Venta
                        span.text-success.fw-bold $#{post.price}

                  - const postTags = post.tagsList || (post.dataValues && post.dataValues.tagsList) || []
                  if postTags.length > 0
                    .d-flex.flex-wrap.gap-2.mb-3
                      each tag in postTags
                        span.badge.rounded-pill.bg-dark.text-light.border.border-secondary(style="font-weight: 500; padding: 6px 12px;") ##{tag}
                  
                  .mt-2.mb-3
                    a.text-decoration-none.fw-bold.me-2.fs-5(href=`/profile/${post.userId}` style="color: inherit;") #{post.user ? post.user.username : 'Usuario'}
                    h5.fw-bold.mb-1.mt-2 #{post.title}
                    p.card-text.text-muted.mb-3 #{post.descriptionText}
                  p.text-muted.small.mb-0.border-bottom.pb-3 #{new Date(post.date).toLocaleString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' })}

                  .comments-section.mt-3
                    if post.comments && post.comments.length > 0
                      each comment in post.comments
                        .d-flex.mb-2.align-items-start.justify-content-between
                          .d-flex.align-items-start
                            if comment.user && comment.user.avatarUrl
                              img.rounded-circle.me-2(src=comment.user.avatarUrl alt="Avatar" width="30" height="30" style="object-fit: cover;")
                            else
                              i.bi.bi-person-circle.fs-4.me-2(style="color: var(--text-muted); line-height: 1;")
                            div
                              span.fw-bold.me-2.small #{comment.user ? comment.user.username : 'Usuario'}
                              span.small #{comment.content}
                          if user && comment.userId !== user.id
                            button.btn.btn-link.text-muted.p-0.ms-2(type="button" title="Reportar comentario" data-bs-toggle="modal" data-bs-target=`#reportCommentModal-${comment.id}`)
                              i.bi.bi-flag
                    else
                      p.text-muted.small No hay comentarios todavía. Sé el primero en comentar.
                    
                    if post.allowComments
                      if user
                        form.d-flex.mt-3(action=`/posts/comment/${post.id}` method="POST")
                          input.form-control.form-control-sm.me-2.border-secondary(id=`comment-input-${post.id}` type="text" name="content" placeholder="Agregar un comentario..." required)
                          button.btn.btn-sm.btn-primary.fw-bold(type="submit") Publicar
                    else
                      p.text-muted.small.mt-3.fst-italic Los comentarios están cerrados.
          else
            .alert.text-center.border-0.shadow-sm(style="background-color: var(--bg-surface); color: var(--text-main); border-radius: 12px; padding: 3rem 1rem;")
              i.bi.bi-camera.fs-1.mb-3.d-block(style="color: var(--text-muted);")
              h4.fw-bold No hay publicaciones disponibles
              p.text-muted Todavía no hay fotos en nuestra comunidad. ¡Animate a subir la primera!

    if posts && posts.length > 0
      each post in posts
        if user && post.userId !== user.id
          .modal.fade(id=`reportPostModal-${post.id}` tabindex="-1")
            .modal-dialog
              .modal-content(style="background-color: var(--bg-surface);")
                .modal-header.border-secondary
                  h5.modal-title.fw-bold Reportar Publicación
                  button.btn-close(type="button" data-bs-dismiss="modal")
                .modal-body
                  form(action=`/posts/${post.id}/report` method="POST")
                    .mb-3
                        label.form-label.text-muted Explicación / Motivo del reporte
                        textarea.form-control.border-secondary.bg-transparent(name="reason" required rows="3" placeholder="Por favor, detallá por qué estás reportando esta publicación...")
                    .text-end
                      button.btn.btn-danger(type="submit") Enviar Reporte

        if post.comments && post.comments.length > 0
          each comment in post.comments
            if user && comment.userId !== user.id
              .modal.fade(id=`reportCommentModal-${comment.id}` tabindex="-1")
                .modal-dialog
                  .modal-content(style="background-color: var(--bg-surface);")
                    .modal-header.border-secondary
                      h5.modal-title.fw-bold Reportar Comentario
                      button.btn-close(type="button" data-bs-dismiss="modal")
                    .modal-body
                      form(action=`/posts/comment/${comment.id}/report` method="POST")
                        .mb-3
                          label.form-label.text-muted Explicación / Motivo del reporte
                          textarea.form-control.border-secondary.bg-transparent(name="reason" required rows="3" placeholder="Por favor, detallá por qué estás reportando este comentario...")
                        .text-end
                          button.btn.btn-danger(type="submit") Enviar Reporte

    if user
      a.btn.btn-primary.position-fixed.bottom-0.end-0.m-4.rounded-circle.shadow-lg.d-flex.justify-content-center.align-items-center(href="/posts/create" style="width: 60px; height: 60px; z-index: 1000;" title="Subir Foto")
        i.bi.bi-plus-lg.fs-3