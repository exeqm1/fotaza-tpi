extends layouts/main.pug

block content
  .container
    .row.mb-5.text-center
      .col
        h1.fw-bold.mb-2 Explorar Feed
        p.text-muted Descubrí las mejores fotografías de nuestra comunidad.

    .row.justify-content-center
      .col-12.col-md-8.col-lg-6
        .d-flex.flex-column.gap-5.mb-5
          each val in [1, 2, 3, 4, 5, 6]
            .card.border-0.post-card
              .card-header.bg-transparent.border-0.d-flex.align-items-center.py-3
                img.rounded-circle.me-3(src=`https://i.pravatar.cc/150?u=${val}` alt="Avatar" width="40" height="40")
                span.fw-bold Usuario#{val}
              
              img.card-img-top.rounded-0(src=`https://picsum.photos/seed/${val * 10}/600/600` alt="Post image" style="object-fit: cover; max-height: 600px;")
              
              .card-body
                .d-flex.justify-content-between.align-items-center.mb-3
                  div
                    i.bi.bi-heart-fill.like-btn(id="likeBtn")
                    i.bi.bi-chat-dots.comment-btn(id="commentBtn")
                  div
                    span.badge.me-2(style="background-color: var(--accent)") Fotografía
                    if val % 2 === 0
                      span.badge.bg-success En Venta $#{val * 150}
                
                p.fw-bold.mb-1 #{val * 12} Me gusta
                
                p.card-text.mb-1
                  span.fw-bold.me-2 Usuario#{val}
                  | Fotaza Título #{val} - Un pequeño texto de descripción para simular lo que escribió el autor en esta publicación.
                p.text-muted.small.mb-0 HACE 2 HORAS